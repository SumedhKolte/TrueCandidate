# Supabase project (Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key: the backend is trusted and must bypass RLS. NEVER ship to frontend.
SUPABASE_SERVICE_KEY=eyJ...

# Groq (https://console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Hard latency budget for any single Groq call (seconds).
# If exceeded we degrade gracefully: skip the LLM signal, keep the pipeline hot.
GROQ_TIMEOUT_S=0.45

# --- Self-hosted Meet bot (optional) ----------------------------------------
# Meet blocks anonymous guests from most calls, so the bot needs a signed-in
# Chrome profile. Create it once:  python -m bot.login
# (Or skip the bot entirely and use the Chrome extension in extension/.)
MEET_BOT_PROFILE_DIR=

# --- Real meetings via Recall.ai (optional; simulator works without these) ---
# API key from https://recall.ai dashboard
RECALL_API_KEY=
# Region base URL shown in your Recall dashboard (us-east-1 / us-west-2 / eu-central-1 / ap-northeast-1)
RECALL_API_BASE=https://us-east-1.recall.ai/api/v1
# Public HTTPS URL of this backend: your Render URL, or `ngrok http 8000` for local dev
PUBLIC_BASE_URL=
